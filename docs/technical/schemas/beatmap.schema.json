{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://meterfall/schemas/beatmap.schema.json",
  "title": "Beatmap",
  "description": "Authored musical timeline for one track: BPM, meter sequence, and timed gameplay events. Referenced by encounter.schema.json via trackId.",
  "type": "object",
  "required": ["trackId", "bpm", "meterSequence", "subdivision", "events"],
  "additionalProperties": false,
  "properties": {
    "trackId": { "type": "string", "description": "Unique identifier matching the audio asset pipeline." },
    "bpm": { "type": "number", "exclusiveMinimum": 0 },
    "meterSequence": {
      "type": "array",
      "minItems": 1,
      "description": "Ordered list of true time-signature segments. Rhythmic patterns like clave are NOT represented here — see encounter.accentProfile.",
      "items": {
        "type": "object",
        "required": ["startBar", "bars", "num", "den"],
        "additionalProperties": false,
        "properties": {
          "startBar": { "type": "integer", "minimum": 1 },
          "bars": { "type": "integer", "minimum": 1 },
          "num": { "type": "integer", "minimum": 1, "description": "Time signature numerator, e.g. 5 in 5/4." },
          "den": { "type": "integer", "enum": [2, 4, 8, 16], "description": "Time signature denominator note value." }
        }
      }
    },
    "subdivision": { "type": "integer", "enum": [4, 8, 16, 32], "description": "Steps per bar used for event quantization." },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["bar", "step", "type"],
        "additionalProperties": true,
        "properties": {
          "bar": { "type": "integer", "minimum": 1 },
          "step": { "type": "integer", "minimum": 0 },
          "type": {
            "type": "string",
            "enum": ["downbeat", "enemyTelegraph", "phaseTransition", "forecastMarker", "syncopationAccent"]
          },
          "payload": { "description": "Type-specific data, e.g. telegraph id or phase name." }
        }
      }
    }
  }
}
